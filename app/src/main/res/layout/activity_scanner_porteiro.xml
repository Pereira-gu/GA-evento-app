<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTituloPorteiro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Controle de Acesso"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvNomeEventoSelecionado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Evento: Carregando..."
        android:textSize="16sp"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btnAbrirScanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Escanear QR Code"
        android:padding="16dp" />

    <TextView
        android:id="@+id/tvResultado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aguardando leitura..."
        android:layout_marginTop="32dp"
        android:textAlignment="center" />

    <Button
        android:id="@+id/btnVoltarSelecao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trocar de Evento / Voltar"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_marginTop="24dp" />

</LinearLayout>